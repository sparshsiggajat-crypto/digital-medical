# ========================================================
# CUREWELL OS: SYSTEM ENVIRONMENT PARAMETERS (EXAMPLE)
# ========================================================

# Frontend Configuration
# Sets the backend base URL for the React application.
# If blank, the client defaults to relative API paths.
VITE_API_URL=/api

# Flask Backend Parameters
# Main application entry file
FLASK_APP=app.py

# Active Python runtime environment profile
FLASK_ENV=development

# Web Security Signature Key for tokens and passwords
SECRET_KEY=medical-shop-secret-key-2026

# Backend Database Connection Socket Path
# Supports standard PostgreSQL, MySQL, and falls back to local serverless SQLite.
# For SQLite, use 'sqlite:///medical_shop.db'
DATABASE_URL=sqlite:///medical_shop.db

# Optional Port Override for localhost proxying
PORT=3000
